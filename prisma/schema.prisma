generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public", "auth"]
}

model Profile {
  id          String   @id @db.Uuid
  email       String   @unique
  fullName    String?  @map("full_name")
  displayName String?  @map("display_name")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  subjects    StudySubject[]
  languages   UserLanguage[]
  exercises   ExerciseType[]
  books       Book[]
  templates   RoutineTemplate[]
  dailyRoutines DailyRoutine[]
  streak      UserStreak?
  studyLogs   StudyLog[]
  languageLogs LanguageLog[]
  exerciseLogs ExerciseLog[]
  bookLogs    BookLog[]
  journalLogs JournalLog[]
  sleepLogs   SleepLog[]
  todoItems   TodoItem[]

  @@map("profiles")
  @@schema("public")
}

model StudySubject {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  name           String   @db.VarChar(100)
  nameNormalized String   @map("name_normalized") @db.VarChar(100)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  profile        Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  studyLogs      StudyLog[]

  @@unique([userId, nameNormalized])
  @@map("study_subjects")
  @@schema("public")
}

model UserLanguage {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  name           String   @db.VarChar(100)
  nameNormalized String   @map("name_normalized") @db.VarChar(100)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  profile        Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  languageLogs   LanguageLog[]

  @@unique([userId, nameNormalized])
  @@map("user_languages")
  @@schema("public")
}

model ExerciseType {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  name           String   @db.VarChar(100)
  nameNormalized String   @map("name_normalized") @db.VarChar(100)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  profile        Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)
  exerciseLogs   ExerciseLog[]

  @@unique([userId, nameNormalized])
  @@map("exercise_types")
  @@schema("public")
}

model Book {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String     @map("user_id") @db.Uuid
  title     String     @db.VarChar(255)
  author    String?    @db.VarChar(255)
  status    BookStatus @default(reading)
  createdAt DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  profile   Profile    @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookLogs  BookLog[]

  @@map("books")
  @@schema("public")
}

model RoutineTemplate {
  id         String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String         @map("user_id") @db.Uuid
  name       String         @db.VarChar(100)
  daysOfWeek Int[]          @map("days_of_week")
  isActive   Boolean        @default(true) @map("is_active")
  createdAt  DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  profile    Profile        @relation(fields: [userId], references: [id], onDelete: Cascade)
  blocks     RoutineBlock[]
  dailyRoutines DailyRoutine[]

  @@map("routine_templates")
  @@schema("public")
}

model RoutineBlock {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  templateId      String          @map("template_id") @db.Uuid
  blockType       RoutineBlockType @map("block_type")
  referenceId     String?         @map("reference_id") @db.Uuid
  referenceName   String?         @map("reference_name") @db.VarChar(255)
  startTime       DateTime?       @map("start_time") @db.Time(0)
  endTime         DateTime?       @map("end_time") @db.Time(0)
  durationMinutes Int             @default(30) @map("duration_minutes")
  sortOrder       Int             @default(0) @map("sort_order")
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  template        RoutineTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@map("routine_blocks")
  @@schema("public")
}

model DailyRoutine {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String             @map("user_id") @db.Uuid
  routineDate     DateTime           @map("routine_date") @db.Date
  templateId      String?            @map("template_id") @db.Uuid
  templateName    String             @map("template_name") @db.VarChar(100)
  scorePercentage Int                @default(0) @map("score_percentage")
  isSetupLocked   Boolean            @default(false) @map("is_setup_locked")
  setupLockedAt   DateTime?          @map("setup_locked_at") @db.Timestamptz(6)
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)
  profile         Profile            @relation(fields: [userId], references: [id], onDelete: Cascade)
  template        RoutineTemplate?   @relation(fields: [templateId], references: [id], onDelete: SetNull)
  items           DailyRoutineItem[]

  @@unique([userId, routineDate])
  @@map("daily_routines")
  @@schema("public")
}

model DailyRoutineItem {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  dailyRoutineId  String           @map("daily_routine_id") @db.Uuid
  sourceBlockId   String?          @map("source_block_id") @db.Uuid
  blockType       RoutineBlockType @map("block_type")
  referenceId     String?          @map("reference_id") @db.Uuid
  referenceName   String?          @map("reference_name") @db.VarChar(255)
  displayName     String           @map("display_name") @db.VarChar(255)
  startTime       DateTime?        @map("start_time") @db.Time(0)
  endTime         DateTime?        @map("end_time") @db.Time(0)
  durationMinutes Int              @map("duration_minutes")
  actualDuration  Int?             @map("actual_duration")
  sortOrder       Int              @map("sort_order")
  isCompleted     Boolean          @default(false) @map("is_completed")
  isSkipped       Boolean          @default(false) @map("is_skipped")
  isSetupPlaceholder Boolean        @default(false) @map("is_setup_placeholder")
  skipReason      String?          @map("skip_reason") @db.VarChar(255)
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6)
  dailyRoutine    DailyRoutine     @relation(fields: [dailyRoutineId], references: [id], onDelete: Cascade)
  studyLogs       StudyLog[]
  languageLogs    LanguageLog[]
  exerciseLogs    ExerciseLog[]
  bookLogs        BookLog[]
  journalLogs     JournalLog[]
  sleepLogs       SleepLog[]

  @@map("daily_routine_items")
  @@schema("public")
}

model UserStreak {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  currentStreak     Int      @default(0) @map("current_streak")
  longestStreak     Int      @default(0) @map("longest_streak")
  lastActiveDate    DateTime? @map("last_active_date") @db.Date
  lastEvaluatedDate DateTime? @map("last_evaluated_date") @db.Date
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  profile           Profile  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_streaks")
  @@schema("public")
}

model StudyLog {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String            @map("user_id") @db.Uuid
  subjectId          String            @map("subject_id") @db.Uuid
  dailyRoutineItemId String?           @map("daily_routine_item_id") @db.Uuid
  logDate            DateTime          @map("log_date") @db.Date
  durationMinutes    Int               @map("duration_minutes")
  activity           String?           @db.VarChar(255)
  material           String?           @db.VarChar(255)
  summary            String?
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  profile            Profile           @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject            StudySubject      @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  dailyRoutineItem   DailyRoutineItem? @relation(fields: [dailyRoutineItemId], references: [id], onDelete: SetNull)

  @@map("study_logs")
  @@schema("public")
}

model LanguageLog {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String            @map("user_id") @db.Uuid
  languageId         String            @map("language_id") @db.Uuid
  dailyRoutineItemId String?           @map("daily_routine_item_id") @db.Uuid
  logDate            DateTime          @map("log_date") @db.Date
  durationMinutes    Int               @map("duration_minutes")
  material           String?           @db.VarChar(255)
  vocabulary         String?
  notes              String?
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  profile            Profile           @relation(fields: [userId], references: [id], onDelete: Cascade)
  language           UserLanguage      @relation(fields: [languageId], references: [id], onDelete: Cascade)
  dailyRoutineItem   DailyRoutineItem? @relation(fields: [dailyRoutineItemId], references: [id], onDelete: SetNull)

  @@map("language_logs")
  @@schema("public")
}

model ExerciseLog {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String            @map("user_id") @db.Uuid
  exerciseTypeId     String            @map("exercise_type_id") @db.Uuid
  dailyRoutineItemId String?           @map("daily_routine_item_id") @db.Uuid
  logDate            DateTime          @map("log_date") @db.Date
  durationMinutes    Int               @map("duration_minutes")
  sets               Int?
  reps               Int?
  notes              String?
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  profile            Profile           @relation(fields: [userId], references: [id], onDelete: Cascade)
  exerciseType       ExerciseType      @relation(fields: [exerciseTypeId], references: [id], onDelete: Cascade)
  dailyRoutineItem   DailyRoutineItem? @relation(fields: [dailyRoutineItemId], references: [id], onDelete: SetNull)

  @@map("exercise_logs")
  @@schema("public")
}

model BookLog {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String            @map("user_id") @db.Uuid
  bookId             String            @map("book_id") @db.Uuid
  dailyRoutineItemId String?           @map("daily_routine_item_id") @db.Uuid
  logDate            DateTime          @map("log_date") @db.Date
  durationMinutes    Int               @map("duration_minutes")
  pagesRead          Int?              @map("pages_read")
  notes              String?
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  profile            Profile           @relation(fields: [userId], references: [id], onDelete: Cascade)
  book               Book              @relation(fields: [bookId], references: [id], onDelete: Cascade)
  dailyRoutineItem   DailyRoutineItem? @relation(fields: [dailyRoutineItemId], references: [id], onDelete: SetNull)

  @@map("book_logs")
  @@schema("public")
}

model JournalLog {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String            @map("user_id") @db.Uuid
  dailyRoutineItemId String?           @map("daily_routine_item_id") @db.Uuid
  logDate            DateTime          @map("log_date") @db.Date
  journalType        JournalType       @map("journal_type")
  plans              String?
  reflection         String?
  notes              String?
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6)
  profile            Profile           @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyRoutineItem   DailyRoutineItem? @relation(fields: [dailyRoutineItemId], references: [id], onDelete: SetNull)

  @@map("journal_logs")
  @@schema("public")
}

model SleepLog {
  id                 String            @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String            @map("user_id") @db.Uuid
  dailyRoutineItemId String?           @map("daily_routine_item_id") @db.Uuid
  wakeDate           DateTime          @map("wake_date") @db.Date
  sleepTime          DateTime          @map("sleep_time") @db.Time(0)
  wakeTime           DateTime          @map("wake_time") @db.Time(0)
  durationMinutes    Int               @map("duration_minutes")
  notes              String?
  createdAt          DateTime          @default(now()) @map("created_at") @db.Timestamptz(6)
  profile            Profile           @relation(fields: [userId], references: [id], onDelete: Cascade)
  dailyRoutineItem   DailyRoutineItem? @relation(fields: [dailyRoutineItemId], references: [id], onDelete: SetNull)

  @@unique([userId, wakeDate])
  @@map("sleep_logs")
  @@schema("public")
}

model TodoItem {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  title       String    @db.VarChar(160)
  dueDate     DateTime? @map("due_date") @db.Date
  isCompleted Boolean   @default(false) @map("is_completed")
  completedAt DateTime? @map("completed_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  profile     Profile   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("todo_items")
  @@schema("public")
}

enum BookStatus {
  reading
  completed
  paused

  @@map("book_status")
  @@schema("public")
}

enum RoutineBlockType {
  study
  language
  exercise
  book
  sleep
  morning_journal
  night_journal
  custom

  @@map("routine_block_type")
  @@schema("public")
}

enum JournalType {
  morning
  night

  @@map("journal_type")
  @@schema("public")
}
